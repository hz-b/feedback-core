record(longout, "$(IOC_NAME):setParameterValue")
{
	field(SCAN, "Passive")
	field(DESC, "Set Parameter")
	field(DTYP, "SETFB COMMON")
	field(OUT, "@VAL")
}
record(longout, "$(IOC_NAME):setInputNode")
{
	field(SCAN, "Passive")
	field(DESC, "Set Input Node")
	field(DTYP, "SETFB COMMON")
	field(OUT, "@INODE")
	field(HOPR, "7")
	field(LOPR, "0")
	field(HIHI, "8")
	field(HIGH, "8")
	field(LOW, "-1")
	field(LOLO, "-1")
	field(HHSV, "MAJOR")
	field(HSV, "MINOR")
	field(LSV, "MINOR")
	field(LLSV, "MAJOR")
}
record(longout, "$(IOC_NAME):setOutputNode")
{
	field(SCAN, "Passive")
	field(DESC, "Set Output Signal")
	field(DTYP, "SETFB COMMON")
	field(OUT, "@ONODE")
	field(HOPR, "7")
	field(LOPR, "0")
	field(HIHI, "8")
	field(HIGH, "8")
	field(LOW, "-1")
	field(LOLO, "-1")
	field(HHSV, "MAJOR")
	field(HSV, "MINOR")
	field(LSV, "MINOR")
	field(LLSV, "MAJOR")
}
record(longout, "$(IOC_NAME):loProcOut")
{
        field(SCAN, "Passive")
        field(PINI, "1")
        field(DESC, "Process Output Node")
        field(PRIO, "HIGH")
        field(DTYP, "SETFB COMMON")
        field(OUT, "@PROC_ONODE")
        field(HOPR, "7")
        field(LOPR, "0")
        field(HIHI, "8")
        field(HIGH, "8")
        field(LOW, "-1")
        field(LOLO, "-1")
        field(HHSV, "MAJOR")
        field(HSV, "MINOR")
        field(LSV, "MINOR")
        field(LLSV, "MAJOR")
}
record(longout, "$(IOC_NAME):loProcIn")
{
        field(SCAN, "Passive")
        field(PINI, "1")
        field(DESC, "Process Output Node")
        field(PRIO, "HIGH")
        field(DTYP, "SETFB COMMON")
        field(OUT, "@PROC_INODE")
        field(HOPR, "7")
        field(LOPR, "0")
        field(HIHI, "8")
        field(HIGH, "8")
        field(LOW, "-1")
        field(LOLO, "-1")
        field(HHSV, "MAJOR")
        field(HSV, "MINOR")
        field(LSV, "MINOR")
        field(LLSV, "MAJOR")
}
record(longout, "$(IOC_NAME):setInputSignal")
{
	field(SCAN, "Passive")
	field(DESC, "Set Output Node")
	field(DTYP, "SETFB COMMON")
	field(OUT, "@ISIG")
	field(FLNK, "$(IOC_NAME):inputSignal")
}
record(longout, "$(IOC_NAME):setOutputSignal")
{
	field(SCAN, "Passive")
	field(DESC, "Set Output Signal")
	field(DTYP, "SETFB COMMON")
	field(OUT, "@OSIG")
	field(FLNK, "$(IOC_NAME):outputSignal")
}
record(longout, "$(IOC_NAME):setClkRate")
{
	field(SCAN, "Passive")
	field(DESC, "Set Rate")
	field(DTYP, "SETFB COMMON")
	field(OUT, "@RATE")
	field(FLNK, "$(IOC_NAME):clkRate")
}
record(longout, "$(IOC_NAME):setSoftTaskRate")
{
	field(SCAN, "Passive")
	field(DESC, "Set Rate")
	field(DTYP, "SETFB COMMON")
	field(OUT, "@SOFTTRIGGERRATE")
	field(FLNK, "$(IOC_NAME):softTaskRate")
}
record(longout, "$(IOC_NAME):setTaskPriority")
{
	field(SCAN, "Passive")
	field(DESC, "Set Priority")
	field(DTYP, "SETFB COMMON")
	field(OUT, "@PRIORITY")
	field(FLNK, "$(IOC_NAME):taskPriority")
}
record(mbbo, "$(IOC_NAME):setInputNode")
{
        field(DESC,"Set Feedback Plugin")
        field(DTYP,"SETFB COMMON MBBO")
        field(OUT, "@INODE")
        field(PINI, "YES")
        field(FLNK, "$(IOC_NAME):mbbiFbInode")
}
record(mbbo, "$(IOC_NAME):setOutputNode")
{
        field(DESC,"Set Feedback Plugin")
        field(DTYP,"SETFB COMMON MBBO")
        field(OUT, "@ONODE")
        field(PINI, "YES")
        field(FLNK, "$(IOC_NAME):mbbiFbOnode")
}
