# Example records for the Feedback Analog Input device support.
# The plugin publishes samples with fbAnalogSet(channel, value).
# These records process via I/O Intr and use the high-priority scan queue.

record(ai, "$(IOC_NAME):AI0") {
    field(DTYP, "Feedback Analog Input")
    field(SCAN, "I/O Intr")
    field(PRIO, "HIGH")
    field(INP,  "@AIN,0")
    field(PREC, "6")
}

