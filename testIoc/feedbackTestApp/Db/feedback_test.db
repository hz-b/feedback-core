record(ai, "$(P)AI0") {
    field(DESC, "Feedback analog channel 0")
    field(DTYP, "Feedback Analog Input")
    field(SCAN, "I/O Intr")
    field(PRIO, "HIGH")
    field(INP,  "@AIN,0")
    field(PREC, "6")
}

